{
  "expo": {
    "name": "fayth",
    "slug": "fayth",
    "version": "0.0.1",
    "scheme": "fayth",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#2f9468"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "life.fayth.patient"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2f9468"
      },
      "package": "life.fayth.patient"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-device",
      "expo-constants",
      "expo-haptics"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "59b7fb35-e6f2-4f0b-b1e9-83e8f88427f9"
      }
    },
    "owner": "suriii"
  }
}
